# =================
# ГЛАВНОЕ ДЛЯ СБОРКИ (Порядок важен!)
# =================

# Сначала запрещаем все jar-файлы (артефакты сборки)
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Потом РАЗРЕШАЕМ только те jar-файлы, которые нужны для запуска сборки (Wrapper)
# Это критически важно для CI/CD (Amvera)
!gradle/wrapper/gradle-wrapper.jar
!.mvn/wrapper/maven-wrapper.jar


# =================
# Компилированные файлы и кэш сборки
# =================
*.class
.gradle/
build/
target/
bin/
tmp/
.apt_generated/
.cache-main
.scala_dependencies
.worksheet


# =================
