.idea/
*.iml
*.iws
*.ipr
.vscode/
.settings/
.project
.classpath
.springBeans
.sts4-cache/
.recommenders/
.metadata/
.loadpath
.factorypath
.cproject
.autotools
.buildpath
.tern-project
.texlipse
.externalToolBuilders/
*.launch
.apt_generated/


# =================
